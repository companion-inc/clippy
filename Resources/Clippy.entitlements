<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened runtime (required for notarization) blocks these capabilities
         unless explicitly granted. Clippy records the mic for Deepgram STT and
         drives apps via Apple Events. Not sandboxed, so files/network/subprocess
         (claude, codex, ClippyMCP) need no extra entitlements. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
